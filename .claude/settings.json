{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/target/debug/ctx-context --hook 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/target/debug/ctx-scan \"$CLAUDE_PROJECT_DIR\" --stop-hook 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
