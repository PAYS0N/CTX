target/
**/*.rs.bk
Cargo.lock.bak

# Secrets. `.env` holds ANTHROPIC_API_KEY for the agent adapter; never
# commit it. `.env.example` is the committed, keyless template.
.env

# Per-task cache and reports. Generated context files (rollup.ctx, *.ctx,
# intent.md) ARE committed.
.context/.cache/
.context/.reports/

# Cage dry-run scratch (host-prepared seed bound into the cage)
sandbox/.seed/

__pycache__
