target/
**/*.rs.bk
Cargo.lock.bak

# Secrets. `.env` holds ANTHROPIC_API_KEY for the agent adapter; never
# commit it. `.env.example` is the committed, keyless template.
.env

# Non-secret local sandbox config for ctx-cage (CTX_CAGE_EXTRA_PATH
# etc.), loaded automatically from CWD; kept separate from `.env`
# since it holds no secrets. `.cagevars.example` is the committed template.
.cagevars

# Per-task cache and reports. Generated context files (rollup.ctx, *.ctx,
# intent.md) ARE committed.
.context/.cache/
.context/.reports/

# Cage dry-run scratch (host-prepared seed bound into the cage)
sandbox/.seed/

__pycache__
