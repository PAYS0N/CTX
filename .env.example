# Copy to `.env` and fill in. `.env` is gitignored (never committed).
# Consumed by agents/summarizer-claude.py via the CTX_AGENT_CMD wrapper,
# which `set -a; . .env`s this file before invoking the adapter.

ANTHROPIC_API_KEY=
