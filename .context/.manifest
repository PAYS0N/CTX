# ctx-access manifest — every readable source path + its read
# invocation. Deny-by-default: secrets, binaries, and gitignored
# paths are absent here and refused even if requested directly.
.gitignore	ctx-access read .gitignore --task-id cageb
Cargo.lock	ctx-access read Cargo.lock --task-id cageb
Cargo.toml	ctx-access read Cargo.toml --task-id cageb
README.md	ctx-access read README.md --task-id cageb
agents/README.md	ctx-access read agents/README.md --task-id cageb
agents/__pycache__/summarizer-claude.cpython-311.pyc	ctx-access read agents/__pycache__/summarizer-claude.cpython-311.pyc --task-id cageb
agents/summarizer-claude.py	ctx-access read agents/summarizer-claude.py --task-id cageb
