file: crates/ctx-cage/tests/common/mod.rs
purpose: Shared integration-test helpers providing canned `BwrapConfig`/`ClaudeBinds` fixtures and argv-inspection predicates for bwrap argument-shape tests.
invariants:
  - All helpers return `bool` or a value; no unwrap/expect/panic calls.
external_deps:
  - ctx_cage::bwrap: types under test (BwrapConfig, ClaudeBinds, DiscoveredCrates).
functions:
  - name: sample_config
    signature: pub fn sample_config() -> BwrapConfig
    purpose: Returns a fully-populated `BwrapConfig` with synthetic paths sufficient for argv-shape assertions without requiring real disk paths.
  - name: sample_claude_binds
    signature: pub fn sample_claude_binds() -> ClaudeBinds
    purpose: Returns a `ClaudeBinds` with synthetic paths for `--claude` argv tests.
  - name: has_triplet
    signature: pub fn has_triplet(argv: &[OsString], flag: &str, a: &str, b: &str) -> bool
    purpose: Reports whether `argv` contains the consecutive three-token sequence `flag a b`.
  - name: has_pair
    signature: pub fn has_pair(argv: &[OsString], flag: &str, a: &str) -> bool
    purpose: Reports whether `argv` contains the consecutive two-token sequence `flag a`.
  - name: has_ro_bind
    signature: pub fn has_ro_bind(argv: &[OsString], host: &str, cage: &str) -> bool
    purpose: Checks for `--ro-bind host cage` in argv.
  - name: has_setenv
    signature: pub fn has_setenv(argv: &[OsString], key: &str, val: &str) -> bool
    purpose: Checks for `--setenv key val` in argv.
  - name: has_tmpfs
    signature: pub fn has_tmpfs(argv: &[OsString], cage: &str) -> bool
    purpose: Checks for `--tmpfs cage` in argv.