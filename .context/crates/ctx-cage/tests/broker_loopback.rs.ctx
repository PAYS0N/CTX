file: crates/ctx-cage/tests/broker_loopback.rs
purpose: End-to-end integration tests for the broker over real UnixListener/UnixStream pairs, using a FakeSpawner instead of a subprocess. Covers allowlist enforcement, output forwarding, and argument passthrough.
invariants:
  - Each test uses a unique socket path (pid + atomic counter) to avoid parallel-test collisions.
  - The broker thread is joined after the client exchange; panics surface as CageError.
external_deps:
  - ctx_cage::broker: system under test (serve_one, EXIT_NOT_ALLOWED)
  - ctx_cage::protocol: frame I/O (read_response_frame, write_request, ResponseFrame)
  - ctx_cage::spawn::Spawner: trait implemented by FakeSpawner
functions:
  - name: unique_socket
    signature: fn unique_socket(label: &str) -> PathBuf
    purpose: Returns a unique temp-dir socket path per call using a process-global atomic counter.
  - name: spawn_broker_thread
    signature: fn spawn_broker_thread(listener: UnixListener, spawner: Arc<FakeSpawner>, allowlist: &[&'static str]) -> thread::JoinHandle<Result<(), CageError>>
    purpose: Accepts one connection from the listener and runs serve_one on a background thread.
  - name: drain_response
    signature: fn drain_response(stream: &mut UnixStream) -> Result<(Vec<u8>, u32), CageError>
    purpose: Reads Output frames until Exit, returning accumulated bytes and exit code.
  - name: drive
    signature: fn drive(req: &Request, spawner: &Arc<FakeSpawner>, allowlist: &[&'static str]) -> Result<(Vec<u8>, u32), CageError>
    purpose: Orchestrates a full client-server exchange: binds socket, starts broker thread, sends request, drains response, joins thread.