file: crates/ctx-cage/src/runtime.rs
purpose: Resolves all host-side paths and ephemeral files needed for the cage's `--claude` mode: the real `claude` binary, host credentials, `/etc/resolv.conf`, a minimal `nsswitch.conf`, and a synthesized `~/.claude.json` that satisfies Claude Code onboarding while preserving blinding.
invariants:
  - Synthesized `claude.json` contains only `oauthAccount` from the host; no projects/history are copied.
  - `anonymousId` is a fresh 32-hex-char value per invocation, sourced from `/dev/urandom`.
external_deps:
  - serde_json: builds and serializes the synthesized claude.json config value.
functions:
  - name: resolve_claude_binds
    signature: pub fn resolve_claude_binds(sockdir: &Path) -> Result<ClaudeBinds, CageError>
    purpose: Resolves all host paths and writes ephemeral files into `sockdir`, returning the complete `ClaudeBinds` struct.
  - name: which_claude_realpath
    signature: fn which_claude_realpath() -> Result<PathBuf, CageError>
    purpose: Resolves the real `claude` binary path via `readlink -f $(command -v claude)`, following all symlinks.
  - name: home_credentials_path
    signature: fn home_credentials_path() -> Result<PathBuf, CageError>
    purpose: Returns `$HOME/.claude/.credentials.json`, erroring if `HOME` is unset or the file is absent.
  - name: write_nsswitch
    signature: fn write_nsswitch(sockdir: &Path) -> Result<PathBuf, CageError>
    purpose: Writes the embedded `CAGE_NSSWITCH_CONF` asset to `<sockdir>/cage-nsswitch.conf`.
  - name: synth_claude_config
    signature: fn synth_claude_config(sockdir: &Path) -> Result<PathBuf, CageError>
    purpose: Builds and writes a minimal `claude.json` to `<sockdir>/claude.json`, copying only `oauthAccount` from the host config.
  - name: build_synth_config
    signature: fn build_synth_config(oauth: &serde_json::Value) -> serde_json::Value
    purpose: Constructs the synthesized config JSON with fixed onboarding fields and a fresh anonymous id.