file: crates/ctx-cage/src/lifecycle/serve.rs
purpose: Lifecycle phase 2: binds a Unix socket, runs a broker thread accepting tool requests, execs the cage via `bwrap`, then tears down the broker and returns the cage's exit code.
invariants:
  - Socket file is removed before bind and again after cage exits.
  - Broker loop exits within one `ACCEPT_IDLE` (20 ms) poll cycle after `stop` is set.
  - Only `ctx-access` and `ctx-verify` are brokered; all other tool names are rejected by `ALLOWLIST`.
external_deps:
  - crate::broker::serve_one: handles a single brokered tool request over a Unix stream.
  - crate::bwrap: builds the `bwrap` argv and discovers crate dirs for sandbox bind-mounts.
functions:
  - name: serve_until_exit
    signature: pub fn serve_until_exit(r: &Resolved, prep: &Prep) -> Result<i32, CageError>
    purpose: Binds the broker socket, spawns the broker thread, execs the cage, signals stop, joins, and returns the cage's exit code.
    notes: Returns exit code `1` if the process was killed without leaving a code.
  - name: build_spawner
    signature: fn build_spawner(r: &Resolved) -> Arc<StdSpawner>
    purpose: Constructs the `StdSpawner` mapping tool names to resolved binary paths.
  - name: spawn_broker_thread
    signature: fn spawn_broker_thread(listener: UnixListener, spawner: Arc<StdSpawner>, stop: Arc<AtomicBool>) -> thread::JoinHandle<Result<(), CageError>>
    purpose: Moves the listener and spawner onto a new thread running `run_broker_loop`.
  - name: run_broker_loop
    signature: fn run_broker_loop(listener: &UnixListener, spawner: &StdSpawner, stop: &AtomicBool) -> Result<(), CageError>
    purpose: Nonblocking accept loop that dispatches each connection to `serve_one` and exits when `stop` is set.
  - name: exec_cage
    signature: fn exec_cage(r: &Resolved, prep: &Prep) -> Result<std::process::ExitStatus, CageError>
    purpose: Builds the `bwrap` configuration and spawns `bwrap`, inheriting stdio, waiting for exit.
  - name: cage_cmd_for_mode
    signature: fn cage_cmd_for_mode(mode: &Mode) -> Vec<OsString>
    purpose: Returns the in-cage command vector for the given mode (stub probe, headless claude, or interactive claude).